{
  "manifest_version": 3,
  "name": "Idealista Brain",
  "version": "0.1.0",
  "description": "Analiza una ficha real de Idealista y extrae la ubicación fiable para buscar alquileres cercanos sin salir del contexto real del navegador.",
  "permissions": [
    "activeTab",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "https://www.idealista.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://localhost/*",
    "https://127.0.0.1/*",
    "https://idealista-brain.vercel.app/*"
  ],
  "externally_connectable": {
    "ids": [
      "*"
    ],
    "matches": [
      "http://localhost/*",
      "http://127.0.0.1/*",
      "https://localhost/*",
      "https://127.0.0.1/*",
      "https://idealista-brain.vercel.app/*"
    ]
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Idealista Brain",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.idealista.com/*"
      ],
      "js": [
        "core/domain-core.js",
        "content-script.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
